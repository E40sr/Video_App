
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Random Video Chat</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #18122B 0%, #393053 100%);
      color: #fff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 0;
    }
    header {
      width: 100%;
      background: linear-gradient(90deg, #ff0066, #00ffff);
      color: #fff;
      padding: 24px 0 16px 0;
      text-align: center;
      font-size: 2.2rem;
      font-weight: bold;
      letter-spacing: 2px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      margin-bottom: 24px;
      border-bottom-left-radius: 24px;
      border-bottom-right-radius: 24px;
    }
    .main-card {
      background: rgba(30, 30, 40, 0.95);
      border-radius: 18px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.25);
      padding: 32px 24px 24px 24px;
      margin-bottom: 32px;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 340px;
      max-width: 98vw;
    }
    #videoDiv {
      display: flex;
      gap: 24px;
      margin-bottom: 24px;
      flex-wrap: wrap;
      justify-content: center;
    }
    video {
      width: 320px;
      height: 240px;
      background: #111;
      border: 3px solid #333;
      border-radius: 14px;
      box-shadow: 0 0 18px rgba(0, 255, 255, 0.18);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    video:hover {
      transform: scale(1.03);
      box-shadow: 0 0 28px rgba(255, 0, 255, 0.25);
    }
    #statusMsg {
      margin-bottom: 18px;
      font-size: 1.15rem;
      min-height: 28px;
      color: #00ffff;
      text-align: center;
      font-weight: 500;
      letter-spacing: 1px;
      padding: 4px 0;
      border-radius: 6px;
      background: rgba(0,0,0,0.12);
      box-shadow: 0 2px 8px rgba(0,255,255,0.05);
    }
    #nextBtn {
      padding: 14px 36px;
      font-size: 1.1rem;
      color: #fff;
      background: linear-gradient(45deg, #ff0066, #ff6600);
      border: none;
      border-radius: 10px;
      cursor: pointer;
      box-shadow: 0 4px 16px rgba(255, 0, 102, 0.22);
      transition: all 0.3s cubic-bezier(.25,.8,.25,1);
      font-weight: 600;
      margin-top: 8px;
    }
    #nextBtn:hover {
      background: linear-gradient(45deg, #ff6600, #ff0066);
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 8px 24px rgba(255, 102, 0, 0.32);
    }
    footer {
      width: 100%;
      text-align: center;
      color: #aaa;
      font-size: 1rem;
      padding: 18px 0 10px 0;
      margin-top: auto;
      background: rgba(0,0,0,0.08);
      border-top-left-radius: 18px;
      border-top-right-radius: 18px;
      letter-spacing: 1px;
    }
    @media (max-width: 700px) {
      .main-card {
        min-width: unset;
        padding: 12px 2vw 18px 2vw;
      }
      video {
        width: 96vw;
        height: auto;
      }
      header {
        font-size: 1.3rem;
        padding: 16px 0 10px 0;
      }
    }
  </style>

  <script src="https://unpkg.com/peerjs@1.3.1/dist/peerjs.min.js"></script>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/index.js" defer></script>
</head>
<body>
  <header>
    Random Video Chat
  </header>
  <div class="main-card">
    <div id="videoDiv">
      <video id="myVideo" muted autoplay playsinline></video>
      <video id="remoteVideo" autoplay playsinline></video>
    </div>
    <div id="statusMsg"></div>
    <button id="nextBtn">Next</button>
  </div>
  <footer>
    &copy; <span id="year"></span> Video Chat App &mdash; Powered by WebRTC, PeerJS, and Socket.IO
  </footer>
  <script>
    document.getElementById('year').textContent = new Date().getFullYear();
  </script>
</body>
</html>
